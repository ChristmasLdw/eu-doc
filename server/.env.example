# EU-DOC 后端环境变量配置示例
# 复制此文件为 .env 并填写实际值

# 服务端口
PORT=3007

# 数据库路径
DATABASE_PATH=./data/eu-doc.db

# 文件上传目录
UPLOAD_DIR=./uploads

# 公开访问的文件 URL 前缀
PUBLIC_FILE_BASE_URL=http://localhost:3007

# JWT 密钥（生产环境必须修改为强密码）
JWT_SECRET=eu-doc-secret-key-change-in-production

# 应用环境（development / production）
APP_ENV=development

# SMTP 邮件服务配置（用于发送验证邮件）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@eu-doc.com
SMTP_PASS=your-smtp-password
SMTP_FROM=EU-DOC <noreply@eu-doc.com>

# 前端地址（用于生成邮件中的链接）
FRONTEND_URL=http://localhost:5173/eu-doc
