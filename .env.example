# EU-DOC 环境变量配置
# 复制此文件为 .env 并修改相应配置

# ===== 服务器配置 =====
# 后端服务端口
PORT=3007

# 应用环境：development / production
APP_ENV=development

# ===== 数据库配置 =====
# SQLite 数据库文件路径（相对于 server 目录）
DATABASE_PATH=data/eu-doc.db

# ===== 文件上传配置 =====
# 上传文件存储目录（相对于 server 目录）
UPLOAD_DIR=uploads

# 最大文件大小（字节）
MAX_FILE_SIZE=10485760

# ===== JWT 认证配置 =====
# JWT 密钥（生产环境请修改为随机字符串）
JWT_SECRET=eu-doc-secret-key-change-in-production

# Token 有效期
JWT_EXPIRES_IN=7d

# ===== 前端配置 =====
# 前端基础路径
VITE_APP_BASE_PATH=/eu-doc/

# API 基础地址
VITE_API_BASE_URL=/eu-doc/api

# ===== 文件访问配置 =====
# 文件访问基础 URL（用于生成文件链接）
PUBLIC_FILE_BASE_URL=

# ===== 邮件配置 =====
# SMTP 服务器地址
SMTP_HOST=smtp.example.com

# SMTP 端口
SMTP_PORT=587

# 是否使用 SSL/TLS
SMTP_SECURE=false

# SMTP 用户名
SMTP_USER=noreply@eu-doc.com

# SMTP 密码
SMTP_PASS=your-smtp-password

# 发件人地址
SMTP_FROM=EU-DOC <noreply@eu-doc.com>

# 前端地址（用于生成邮件中的链接）
FRONTEND_URL=http://localhost:5173/eu-doc

# ===== 对象存储配置（预留） =====
# STORAGE_TYPE=local
# COS_BUCKET=
# COS_REGION=
# COS_SECRET_ID=
# COS_SECRET_KEY=
